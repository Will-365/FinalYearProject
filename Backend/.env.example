PORT=5000

# ── Database ────────────────────────────────────────────────────────────────
# LOCAL (recommended for dev — run: docker compose up -d)
MONGODB_URI=mongodb://localhost:27017/greencare

# ATLAS (cloud — requires working internet + IP whitelisted in Atlas)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/greencare?retryWrites=true&w=majority

# ADMIN_EMAIL=admin@greencare.rw
# ADMIN_PASSWORD=GreenCare@2025!

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM=GreenCare Rwanda <your_gmail@gmail.com>
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Gemini AI - Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
